  state0Lines:
  - actorName: Pellomalou
    text: Welcome, my name is Pellomalou.
  - actorName: Pellomalou
    text: Help me find the lantern.
  - actorName: Player
    text: Where did you last see it?
  - actorName: Pellomalou
    text: Near the church.
  state1Lines:
  - actorName: Pellomalou
    text: Did you find it? It was near the church.
  state2Lines:
  - actorName: Pellomalou
    text: You found it? Go talk to Papaskouloukos
  state3Lines:
  - actorName: Pellomalou
    text: Have you helped Papaskouloukos?
  state4Lines:
  - actorName: Pellomalou
    text: 'You found the crosses? Great work! '
  state5Lines:
  - actorName: Pellomalou
    text: Thank you for saving the village!

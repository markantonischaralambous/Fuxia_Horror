      propertyPath: state4Lines.Array.size
      value: 1
      objectReference: {fileID: 0}
    - target: {fileID: 5845863685661548792, guid: 43d2733b9089d674882d303d95f64c7e, type: 3}
      propertyPath: state5Lines.Array.size
      value: 1
      objectReference: {fileID: 0}
    - target: {fileID: 5845863685661548792, guid: 43d2733b9089d674882d303d95f64c7e, type: 3}
      propertyPath: introLines.Array.data[0].text
      value: Hello, im Pellomalou, help me find the lantern.
      objectReference: {fileID: 0}
    - target: {fileID: 5845863685661548792, guid: 43d2733b9089d674882d303d95f64c7e, type: 3}
      propertyPath: state0Lines.Array.data[0].text
      value: Welcome to Palioxori. My name is Pellomalou.
      objectReference: {fileID: 0}
    - target: {fileID: 5845863685661548792, guid: 43d2733b9089d674882d303d95f64c7e, type: 3}
      propertyPath: state0Lines.Array.data[1].text
      value: I lost my lantern, i need help finding it.
      objectReference: {fileID: 0}
    - target: {fileID: 5845863685661548792, guid: 43d2733b9089d674882d303d95f64c7e, type: 3}
      propertyPath: state0Lines.Array.data[2].text
      value: Where have you last seen it?
      objectReference: {fileID: 0}
    - target: {fileID: 5845863685661548792, guid: 43d2733b9089d674882d303d95f64c7e, type: 3}
      propertyPath: state0Lines.Array.data[3].text
      value: 'Near the church. '
      objectReference: {fileID: 0}
    - target: {fileID: 5845863685661548792, guid: 43d2733b9089d674882d303d95f64c7e, type: 3}
      propertyPath: state1Lines.Array.data[0].text
      value: Have you found it?
      objectReference: {fileID: 0}
    - target: {fileID: 5845863685661548792, guid: 43d2733b9089d674882d303d95f64c7e, type: 3}
      propertyPath: state2Lines.Array.data[0].text
      value: You found it? Good work!
      objectReference: {fileID: 0}
    - target: {fileID: 5845863685661548792, guid: 43d2733b9089d674882d303d95f64c7e, type: 3}
      propertyPath: state2Lines.Array.data[1].text
      value: You should go talk to Papaskouloukos, i think he needed help earlier.
      objectReference: {fileID: 0}
    - target: {fileID: 5845863685661548792, guid: 43d2733b9089d674882d303d95f64c7e, type: 3}
      propertyPath: state3Lines.Array.data[0].text
      value: Have you helped him yet?
      objectReference: {fileID: 0}
    - target: {fileID: 5845863685661548792, guid: 43d2733b9089d674882d303d95f64c7e, type: 3}
      propertyPath: state4Lines.Array.data[0].text
      value: You returned the graves? Good work!
      objectReference: {fileID: 0}
    - target: {fileID: 5845863685661548792, guid: 43d2733b9089d674882d303d95f64c7e, type: 3}
      propertyPath: state5Lines.Array.data[0].text
      value: Thank you for saving us!
      objectReference: {fileID: 0}
    - target: {fileID: 5845863685661548792, guid: 43d2733b9089d674882d303d95f64c7e, type: 3}
      propertyPath: genericReminderLines.Array.size
      value: 1
      objectReference: {fileID: 0}
    - target: {fileID: 5845863685661548792, guid: 43d2733b9089d674882d303d95f64c7e, type: 3}
      propertyPath: state0Lines.Array.data[0].actorName
      value: Pellomalou
      objectReference: {fileID: 0}
    - target: {fileID: 5845863685661548792, guid: 43d2733b9089d674882d303d95f64c7e, type: 3}
